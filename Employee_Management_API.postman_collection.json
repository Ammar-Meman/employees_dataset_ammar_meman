{
  "info": {
    "name": "Employee Management API",
    "description": "Complete documentation for the Employee Management Analytics API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_JWT_TOKEN_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Ammar Meman\", \"email\": \"ammar@example.com\", \"password\": \"password123\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"ammar@example.com\", \"password\": \"password123\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh-token",
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\": \"YOUR_REFRESH_TOKEN\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/auth/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "url": "{{baseUrl}}/auth/profile",
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Ammar Updated\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/employees?page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "employees"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Employee by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/employees/E00001"
          }
        },
        {
          "name": "Check Employee Exists",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/employees/exists/E00001"
          }
        },
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/employees",
            "body": {
              "mode": "raw",
              "raw": "{\"id\": \"E00001\",\"name\": \"Test Employee\",\"profile\": {\"contact\": {\"email\": \"test@email.com\",\"phone\": \"+1-123456789\",\"address\": {\"street\": \"123 Test St\",\"city\": \"Test City\",\"location\": {\"state\": \"Test State\",\"country\": \"USA\",\"geo\": {\"lat\": \"0.000\",\"long\": \"0.000\",\"timezone\": {\"name\": \"America/New_York\",\"utc_offset\": \"-05:00\"}}}}}}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Update Employee (PUT)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/employees/E00001",
            "body": {
              "mode": "raw",
              "raw": "{\"id\": \"E00001\",\"name\": \"Updated Employee\",\"profile\": {\"contact\": {\"email\": \"updated@email.com\",\"phone\": \"+1-123456789\",\"address\": {\"street\": \"123 Test St\",\"city\": \"Test City\",\"location\": {\"state\": \"Test State\",\"country\": \"USA\",\"geo\": {\"lat\": \"0.000\",\"long\": \"0.000\",\"timezone\": {\"name\": \"America/New_York\",\"utc_offset\": \"-05:00\"}}}}}}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Update Employee (PATCH)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/employees/E00001",
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Partially Updated Employee\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/employees/E00001"
          }
        },
        {
          "name": "Bulk Create",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/employees/bulk-create",
            "body": {
              "mode": "raw",
              "raw": "[]",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Bulk Update",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/employees/bulk-update",
            "body": {
              "mode": "raw",
              "raw": "{\"filter\": {\"profile.contact.address.location.country\": \"USA\"}, \"updateData\": {\"name\": \"Updated Name\"}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Bulk Delete",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/employees/bulk-delete",
            "body": {
              "mode": "raw",
              "raw": "{\"filter\": {\"profile.contact.address.location.country\": \"USA\"}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Search Employees",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/search/employees?q=Java",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "search",
                "employees"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "Java"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Top Skills",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics/employees/top-skills"
          }
        },
        {
          "name": "Top Domains",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics/employees/top-domains"
          }
        },
        {
          "name": "Location Distribution",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics/employees/location-distribution"
          }
        },
        {
          "name": "Experience Distribution",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics/employees/experience-distribution"
          }
        },
        {
          "name": "Project Distribution",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics/employees/project-distribution"
          }
        },
        {
          "name": "Top Certifications",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics/employees/top-certifications"
          }
        }
      ]
    },
    {
      "name": "Stats",
      "item": [
        {
          "name": "Overview",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/stats/overview"
          }
        }
      ]
    }
  ]
}